          "rawSql": "SELECT\n  time AS \"Time\",\n  ROUND(temp_c::numeric, 1) AS \"Temp °C\",\n  CASE\n    WHEN temp_c < 15 THEN 'Too cold — growth stalled'\n    WHEN temp_c BETWEEN 15 AND 20 THEN 'Slow growth — acceptable'\n    WHEN temp_c BETWEEN 20 AND 24 THEN 'Optimal for tomatoes'\n    WHEN temp_c BETWEEN 24 AND 30 THEN 'Warm — increase watering'\n    ELSE 'Too hot — shade & ventilate'\n  END AS \"Status\"\nFROM measurements\nWHERE node_id = '${node}'\nORDER BY time DESC\nLIMIT 10",
