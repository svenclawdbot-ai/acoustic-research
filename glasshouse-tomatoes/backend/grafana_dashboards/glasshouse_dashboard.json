          "rawSql": "SELECT\n  time AS \"Time\",\n  ROUND(vwc_percent::numeric, 1) AS \"VWC %\",\n  CASE\n    WHEN vwc_percent < 15 THEN 'WATER NOW — Risk of blossom end rot'\n    WHEN vwc_percent BETWEEN 15 AND 25 THEN 'Water soon — within 24h'\n    WHEN vwc_percent BETWEEN 25 AND 40 THEN 'OK — No action needed'\n    WHEN vwc_percent BETWEEN 40 AND 50 THEN 'Too wet — Stop watering, check drainage'\n    ELSE 'SATURATED — Root rot risk! Ventilate & drain'\n  END AS \"Recommendation\"\nFROM measurements\nWHERE node_id = '${node}'\nORDER BY time DESC\nLIMIT 1",
