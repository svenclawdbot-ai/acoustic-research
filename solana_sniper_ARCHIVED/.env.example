# Solana Sniper Bot Environment Variables
# Copy to .env and fill in your values

# Wallet Configuration
SNIPER_PRIVATE_KEY=your_base58_private_key_here
SNIPER_RPC_URL=https://api.mainnet-beta.solana.com
SNIPER_WSS_URL=wss://api.mainnet-beta.solana.com

# Risk Management
SNIPER_MAX_POSITION=0.1
SNIPER_STOP_LOSS=30.0
SNIPER_TP1=3.0
SNIPER_TP2=5.0
SNIPER_DAILY_LOSS_LIMIT=3

# Barbell Allocation
SNIPER_CASH_RESERVE=90.0
SNIPER_ALLOCATION=10.0

# Execution Speed
SNIPER_USE_JITO=true
SNIPER_JITO_TIP=10000
SNIPER_MAX_SLIPPAGE=100
SNIPER_PRIORITY_FEE=10000

# Signal Detection
SNIPER_MIN_LIQUIDITY=1000.0
SNIPER_MIN_VOLUME_5M=5000.0
SNIPER_MAX_ENTRY_DELAY=30
SNIPER_POLL_INTERVAL=5

# Bayesian Inference
SNIPER_CONFIDENCE=0.7
SNIPER_SURPRISE_THRESHOLD=2.0

# Testing
SNIPER_DRY_RUN=true
SNIPER_LOG_LEVEL=DEBUG

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
DASHBOARD_REFRESH_INTERVAL=5
